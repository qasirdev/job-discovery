# Supabase (MVP 2+)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql+asyncpg://...

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_API_BASE=
OPENROUTER_API_KEY=

# Redis (MVP 2+)
REDIS_URL=redis://localhost:6379

# Temporal (MVP 2+)
TEMPORAL_SERVER_URL=

# Observability (MVP 3)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# Analytics (MVP 2+)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# API Gateway (MVP 2+) — JD-103
# Kong configuration (optional — gateway layer runs as FastAPI middleware in MVP 2)
KONG_ADMIN_URL=
KONG_PROXY_URL=

# Auth (MVP 2+) — JD-103
# Secret key for JWT signing (must be a strong random secret in production)
SECRET_KEY=super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Proxy Abstraction Layer (MVP 2+) — JD-104
# Datacenter proxy pool: comma-separated list of proxy URLs
# Format: http://user:pass@host:port,http://user:pass@host2:port2
PROXY_POOL_URLS=
# Residential proxy endpoint: single URL (opt-in — activated on anti-bot detection)
# Format: http://username:password@residential.proxy.net:8080
RESIDENTIAL_PROXY_URL=

# Frontend
NEXT_PUBLIC_API_URL=/api/v1
SINGLE_USER_ID=00000000-0000-0000-0000-000000000000
