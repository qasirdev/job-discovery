FROM python:3.14-slim

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /app

# Install LiteLLM and any python dependencies
RUN uv venv && uv pip install litellm 'litellm[proxy]'

# For llama.cpp, we download the pre-built server binary for simplicity in this MVP
# (In production, this would be compiled with CUDA/Metal flags depending on the target arch)
RUN curl -L https://github.com/ggerganov/llama.cpp/releases/download/b3000/llama-b3000-bin-ubuntu-x64.zip -o llama.zip \
    && apt-get install -y unzip \
    && unzip llama.zip -d llama \
    && mv llama/llama-server /usr/local/bin/ \
    && rm -rf llama.zip llama

COPY . .

EXPOSE 8080 4000

CMD ["sh", "-c", "if [ -z \"$OPENROUTER_API_KEY\" ]; then llama-server -m /models/gpt-oss-120b-q4_k_m.gguf --port 8080 --ctx-size 4096 -ngl 99; else /app/.venv/bin/litellm --model openrouter/auto --port 4000; fi"]
